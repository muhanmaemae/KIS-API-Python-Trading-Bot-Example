# ==========================================================
# 1. 시스템 보안 키 및 환경 설정 (자본 탈취 방어 절대 은폐)
# ==========================================================
config.json
token.dat
.env

# ==========================================================
# 2. 퀀트 장부 및 상태 캐시 데이터 (개인 매매 내역 및 타점 격리)
# ==========================================================
data/
*_backup.json
*.bak

# ==========================================================
# 3. 로그 파일 (시스템 런타임 및 체결 기록 은폐)
# ==========================================================
logs/
*.log

# ==========================================================
# 4. 렌더링 미디어 파일 (개인 수익률 및 졸업 카드 은폐)
# ==========================================================
profit_*.png
profit_*.gif

# ==========================================================
# 5. 파이썬 및 OS 시스템 찌꺼기 (디스크 I/O 파편화 방지)
# ==========================================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.DS_Store
